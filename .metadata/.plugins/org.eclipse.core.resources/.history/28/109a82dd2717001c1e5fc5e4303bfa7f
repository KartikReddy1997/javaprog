import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;

public class Hotstar {

	public static void main(String[] args) {
		
		System.setProperty("webdriver.chrome.driver", "D:\\chromedriver_win32\\chromedriver.exe");
		WebDriver driver=new ChromeDriver(); 
		
		driver.get("https://www.hotstar.com/in");
		driver.findElement(By.xpath("//*[@id=\"searchField\"]")).sendKeys("Game of Thrones");
		driver.findElement(By.xpath("//*[@id=\"app\"]/div/div/div[1]/div[1]/div/div[2]/div/div[4]/div[2]/div[1]/article/a/div[2]/div/span")).click();
		driver.findElement(By.xpath("\r\n"
				+ "//*[@id=\"app\"]/div/div/div[1]/div[2]/div[1]/div/div[3]/div[2]/div/div[1]/div[1]/a/div/div[1]/div"));	
		
	}

}
